!Sample_source_name_ch1 = rice suspension culture
!Sample_organism_ch1 = Oryza sativa
!Sample_taxid_ch1 = 4530
!Sample_characteristics_ch1 = treatment: DMSO
!Sample_characteristics_ch1 = time point (minutes): 30
!Sample_characteristics_ch1 = cultivar: Tsukinohikari
!Sample_characteristics_ch1 = replicate: 1
!Sample_treatment_protocol_ch1 = doesed with 5mM stokcs of metcamifen or cyprosulfamide, prepared in dimethyl fulfoxide (DMSO) to give a final concentration of 5uM, or DMSO alone as control treatmnet.  Cells sampled at 30,90, and 240 minutes.
!Sample_growth_protocol_ch1 = Cell suspension cultures 5 day old; n=3
!Sample_molecule_ch1 = polyA RNA
!Sample_extract_protocol_ch1 = Total RNA was extracted using RiboPureTM RNA Purification Kit (Ambion, Inc.)
